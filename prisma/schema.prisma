generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// ─── Models ───────────────────────────────────────────────────────────────────
// NOTE: SQL Server does not support native Prisma enums.
// Enum-like fields use String with NVarChar(50) and are validated at the
// application layer via Zod schemas.
//
// ProductStatus:   Discovery | Active | Maintenance | Sunset
// Priority:        Critical | High | Medium | Low
// IntentionStatus: Draft | Defined | InProgress | Fulfilled | Deferred
// ExpectationStatus: Draft | Ready | Specced | Validated | Done
// SpecPhase:       Draft | Ready | InProgress | Review | Validating | Done
// Complexity:      Low | Medium | High

model Product {
  id                String   @id @default(uuid())
  name              String   @db.NVarChar(255)
  problem_statement String   @db.NVarChar(Max)
  vision            String   @db.NVarChar(Max)
  target_audience   String   @db.NVarChar(Max)
  status            String   @default("Discovery") @db.NVarChar(50)
  context           String   @db.NVarChar(Max)
  wip_limits        String   @db.NVarChar(Max)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  archived_at       DateTime?

  intentions Intention[]
  specs      Spec[]

  @@map("products")
}

model Intention {
  id          String   @id @default(uuid())
  product_id  String
  title       String   @db.NVarChar(255)
  description String   @db.NVarChar(Max)
  priority    String   @default("Medium") @db.NVarChar(50)
  status      String   @default("Draft") @db.NVarChar(50)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  archived_at DateTime?

  product      Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  expectations Expectation[]

  dependencies_as_source IntentionDependency[] @relation("source")
  dependencies_as_target IntentionDependency[] @relation("target")

  @@map("intentions")
}

model IntentionDependency {
  intention_id  String
  depends_on_id String

  intention  Intention @relation("source", fields: [intention_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  depends_on Intention @relation("target", fields: [depends_on_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([intention_id, depends_on_id])
  @@map("intention_dependencies")
}

model Expectation {
  id           String   @id @default(uuid())
  intention_id String
  title        String   @db.NVarChar(255)
  description  String   @db.NVarChar(Max)
  status       String   @default("Draft") @db.NVarChar(50)
  edge_cases   String   @db.NVarChar(Max)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  archived_at  DateTime?

  intention         Intention         @relation(fields: [intention_id], references: [id], onDelete: Cascade)
  spec_expectations SpecExpectation[]

  @@map("expectations")
}

model Spec {
  id                   String   @id @default(uuid())
  product_id           String
  title                String   @db.NVarChar(255)
  description          String   @db.NVarChar(Max)
  phase                String   @default("Draft") @db.NVarChar(50)
  complexity           String   @default("Medium") @db.NVarChar(50)
  context              String   @db.NVarChar(Max)
  boundaries           String   @db.NVarChar(Max)
  deliverables         String   @db.NVarChar(Max)
  validation_automated String   @db.NVarChar(Max)
  validation_human     String   @db.NVarChar(Max)
  peer_reviewed        Boolean  @default(false)
  phase_changed_at     DateTime @default(now())
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  archived_at          DateTime?

  product           Product           @relation(fields: [product_id], references: [id], onDelete: Cascade)
  spec_expectations SpecExpectation[]
  phase_transitions PhaseTransition[]

  @@map("specs")
}

model SpecExpectation {
  spec_id        String
  expectation_id String

  spec        Spec        @relation(fields: [spec_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expectation Expectation @relation(fields: [expectation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([spec_id, expectation_id])
  @@map("spec_expectations")
}

model PhaseTransition {
  id              String   @id @default(uuid())
  spec_id         String
  from_phase      String   @db.NVarChar(50)
  to_phase        String   @db.NVarChar(50)
  timestamp       DateTime @default(now())
  user_id         String   @db.NVarChar(255)
  override_reason String?  @db.NVarChar(Max)

  spec Spec @relation(fields: [spec_id], references: [id], onDelete: Cascade)

  @@map("phase_transitions")
}
